# انسخ هذا الملف إلى .env واملأ القيم الحقيقية. لا تضع قيماً حقيقية هنا أبداً.

# قاعدة البيانات
DB_URL=jdbc:mysql://localhost:3306/starlink_iraq_store
DB_USERNAME=CHANGE_ME_DB_USERNAME
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
JPA_DDL_AUTO=validate

# JWT (يجب أن يكون طويلاً وعشوائياً بالإنتاج، 256-bit على الأقل)
JWT_SECRET=CHANGE_ME_REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_256_BITS
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# البريد الإلكتروني (لتأكيد الحساب والإشعارات)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_MAIL_USERNAME
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD

# Redis (اختياري - للسلة المؤقتة و rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379

# الأمان
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15

# CORS - دومين الفرونت إند المصرح به فقط
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

SERVER_PORT=8080
LOW_STOCK_THRESHOLD=5

# مفتاح تشفير الأعمدة الحساسة (مثل أكواد التفعيل الرقمية) - يجب أن يكون طويلاً وعشوائياً
DB_ENCRYPTION_SECRET_KEY=CHANGE_ME_32_BYTE_BASE64_ENCODED_AES_KEY
